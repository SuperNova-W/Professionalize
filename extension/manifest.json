{
  "manifest_version": 3,
  "name": "Gmail Reply Orb",
  "description": "Local Gmail reply assistant with tone controls and one-click insertion.",
  "version": "0.1.0",
  "permissions": ["activeTab"],
  "host_permissions": ["http://localhost:3789/*"],
  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ]
}


